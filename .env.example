# Git Graph+ standalone web server configuration.
# Copy to `.env` and adjust. All values are optional; defaults shown below.

# TCP port to listen on.
PORT=8080

# Bind address. Defaults to loopback because the intended access model is
# SSH port-forwarding or Tailscale — do NOT expose 0.0.0.0 on an untrusted
# network without an auth token (and ideally not even then).
HOST=127.0.0.1

# Shared access token. If set and non-empty, the web UI and WebSocket require
# it (entered once via a login page, stored in a session cookie). If empty,
# access is open and SSH/Tailscale is assumed to be the real boundary.
AUTH_TOKEN=

# Root directory to discover git repositories under (repos, submodules, and
# nested repos up to 3 levels deep). `~` is expanded.
ROOT_DIR=~/projects

# Override the git executable. Empty = use `git` from PATH.
GIT_BINARY_PATH=

# Auto-refresh the graph when the repo's .git dir changes (file watcher).
AUTO_REFRESH=true

# Periodic background `git fetch` (mirrors the extension's auto-fetch).
AUTO_FETCH=true
AUTO_FETCH_INTERVAL_MS=180000

# UI locale: auto | en | ko | zh-cn. `auto` follows the host LANG env var.
LOCALE=auto

# Commit sort order: author-date | date | topological.
GRAPH_SORT_ORDER=topological

# Colored branch-badge bar thickness: thin | medium | thick.
BRANCH_BADGE_BAR_THICKNESS=thin
